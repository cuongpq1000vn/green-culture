{
  "kind": "collectionType",
  "collectionName": "process_steps",
  "info": {
    "singularName": "process-step",
    "pluralName": "process-steps",
    "displayName": "Process Step",
    "description": "Steps in the production and export process"
  },
  "options": {
    "draftAndPublish": true,
    "comment": ""
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "content": {
      "type": "richtext",
      "required": false
    },
    "icon": {
      "type": "string",
      "required": false
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "stepNumber": {
      "type": "integer",
      "required": true,
      "min": 1
    },
    "duration": {
      "type": "string",
      "required": false
    },
    "department": {
      "type": "string",
      "required": false
    },
    "tools": {
      "type": "json",
      "required": false
    },
    "qualityChecks": {
      "type": "json",
      "required": false
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}