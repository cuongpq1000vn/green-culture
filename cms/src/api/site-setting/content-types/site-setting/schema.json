{
  "kind": "singleType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Site Settings",
    "description": "Global site settings and configuration"
  },
  "options": {
    "draftAndPublish": false,
    "comment": ""
  },
  "pluginOptions": {},
  "attributes": {
    "siteName": {
      "type": "string",
      "required": true,
      "default": "EGO Agricultural Export"
    },
    "siteDescription": {
      "type": "text",
      "required": false
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "logoAlt": {
      "type": "string",
      "required": false
    },
    "favicon": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "companyInfo": {
      "type": "json",
      "required": false
    },
    "contactInfo": {
      "type": "json",
      "required": false
    },
    "socialLinks": {
      "type": "json",
      "required": false
    },
    "footerText": {
      "type": "richtext",
      "required": false
    },
    "copyrightText": {
      "type": "string",
      "required": false
    },
    "defaultSeo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "gtmId": {
      "type": "string",
      "required": false
    },
    "gaId": {
      "type": "string",
      "required": false
    },
    "primaryColor": {
      "type": "string",
      "required": false,
      "default": "#F5A623"
    },
    "secondaryColor": {
      "type": "string",
      "required": false
    }
  }
}