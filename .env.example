# Strapi CMS Environment Variables
# Copy this file to .env.local and fill in your actual values

# ======================
# Strapi Configuration
# ======================

# Strapi Backend URL (Server-side only - not exposed to client)
# Development: http://localhost:1337
# Production: Your deployed Strapi URL (e.g., https://your-app.railway.app)
STRAPI_URL=http://localhost:1337

# Strapi API Token (Server-side only - not exposed to client)  
# Generate this from Strapi Admin Panel > Settings > API Tokens
# Token Type: Read-only
# Token Duration: Unlimited (for production)
STRAPI_API_TOKEN=your_strapi_read_only_token_here

# Strapi Public URL (Client-side accessible)
# Usually same as STRAPI_URL, but can be different for CDN/proxy setups
# This is used for image URLs and client-side requests
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# ======================
# Database Configuration (Strapi only)
# ======================

# Development (SQLite - no additional config needed)
# Production PostgreSQL (when deploying Strapi)
# DATABASE_URL=postgresql://username:password@host:port/database

# ======================
# File Upload Configuration (Strapi only)  
# ======================

# For production, configure Cloudinary or AWS S3
# CLOUDINARY_NAME=your_cloudinary_cloud_name
# CLOUDINARY_KEY=your_cloudinary_api_key  
# CLOUDINARY_SECRET=your_cloudinary_api_secret

# AWS S3 (alternative to Cloudinary)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=your_aws_region
# AWS_BUCKET=your_s3_bucket_name

# ======================
# Optional Configuration
# ======================

# JWT Secret (auto-generated by Strapi, only needed if customizing)
# JWT_SECRET=your_jwt_secret

# Admin JWT Secret (auto-generated by Strapi)
# ADMIN_JWT_SECRET=your_admin_jwt_secret

# App Keys (auto-generated by Strapi)
# APP_KEYS=key1,key2,key3,key4

# API Token Salt (auto-generated by Strapi)
# API_TOKEN_SALT=your_api_token_salt

# Transfer Token Salt (auto-generated by Strapi)  
# TRANSFER_TOKEN_SALT=your_transfer_token_salt

# ======================
# Next.js Configuration
# ======================

# ISR Revalidation time (seconds)
# How often to regenerate static pages when content changes
# Default: 60 seconds
# NEXT_REVALIDATE_TIME=60

# ======================
# Development Only
# ======================

# Enable Strapi dev mode
# NODE_ENV=development

# Strapi host and port (dev only)
# HOST=0.0.0.0
# PORT=1337